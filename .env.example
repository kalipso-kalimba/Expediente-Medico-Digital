# Variables de entorno para ejecución local
# Copie este archivo como .env y ajuste los valores

# Entorno: local | production
APP_ENV=local

# Clave secreta para sesiones (cambiar en producción)
APP_SECRET_KEY=change_me_to_a_random_secret

# Credenciales del médico
DOCTOR_USERNAME=doctor
DOCTOR_PASSWORD=Cambiar123!

# Cookies seguras (false en local, true en producción con HTTPS)
APP_COOKIE_SECURE=false

# URL base para generar enlaces de pacientes
# Local:  http://127.0.0.1:8000
# Render: https://expediente-medico-digital.onrender.com
BASE_URL=http://127.0.0.1:8000

# Consulta automática al TSE (deshabilitada por defecto)
TSE_LOOKUP_ENABLED=false

# --- Almacenamiento de archivos ---
# Backend: local_path (local o NAS)
STORAGE_BACKEND=local_path

# Ruta raíz del almacenamiento:
# Local:  (dejar vacío para usar ./storage/)
# NAS:    Ruta a la carpeta "Expediente Medico Digital" del usuario OpenCode
#         Ejemplo: Z:\Expediente Medico Digital
#         Ejemplo: /mnt/nas/Expediente Medico Digital
STORAGE_ROOT=

# Nombre de la carpeta raíz de expedientes de pacientes (relativo a STORAGE_ROOT)
PATIENT_FILES_ROOT=Expediente de pacientes
